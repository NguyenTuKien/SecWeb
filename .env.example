APP_NAME=mini-messenger
SERVER_PORT=8080
DOCKER_COMPOSE_ENABLED=false

DB_HOST=localhost
DB_PORT=3306
DB_NAME=mini_messenger
DB_USERNAME=root
DB_PASSWORD=mini_password
JPA_DDL_AUTO=update

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=3s

JWT_SECRET=CHANGE_ME_MINIMUM_32_BYTES_SECRET
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

GOOGLE_CLIENT_ID=PASTE_GOOGLE_OAUTH_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=PASTE_GOOGLE_OAUTH_CLIENT_SECRET_HERE_IF_NEEDED
GOOGLE_ALLOWED_AUDIENCES=PASTE_WEB_CLIENT_ID_HERE,PASTE_ANDROID_CLIENT_ID_HERE

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

ADMIN_SEED_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@local.dev
# These bootstrap master-key values are placeholders so admin can log in.
# Replace them with client-generated E2EE values if the admin account will join conversations.
ADMIN_MASTER_PUBLIC_KEY=YWRtaW4tcHVibGljLWtleS1wbGFjZWhvbGRlcg==
ADMIN_ENCRYPTED_PRIVATE_KEY=YWRtaW4tZW5jcnlwdGVkLXByaXZhdGUta2V5LWhvbGRlcg==
ADMIN_PRIVATE_KEY_IV=YWRtaW4taXY=
ADMIN_PIN_SALT=YWRtaW4tc2FsdA==
ADMIN_KDF_PARAMS={"algorithm":"PBKDF2","iterations":100000,"keyLength":256,"digest":"SHA-256","bootstrap":true}
