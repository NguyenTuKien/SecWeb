# DATABASE
MYSQL_DATABASE=database 
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USER=user
MYSQL_PASSWORD=password

# REDIS
REDIS_PASSWORD=redis_password   

# BACKEND
SPRING_DOCKER_COMPOSE_ENABLED=false
SPRING_DATASOURCE_URL=jdbc:mysql://database:3306/database?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password
SPRING_JPA_HIBERNATE_DDL_AUTO=update    

# Sửa lỗi chính tả và pass khớp với REDIS_PASSWORD ở trên
SPRING_DATA_REDIS_URL=redis://:redis_password@redis:6379
SPRING_DATA_REDIS_TIMEOUT=3s
SPRING_DATA_REDIS_REPOSITORY_ENABLED=false

APP_JWT_SECRET=CHANGE_ME_MINIMUM_32_BYTES_SECRET
APP_JWT_ACCESS_TOKEN_TTL_MINUTES=15
APP_JWT_REFRESH_TOKEN_TTL_DAYS=30

APP_GOOGLE_CLIENT_ID=PASTE_WEB_CLIENT_ID_HERE
APP_GOOGLE_CLIENT_SECRET=PASTE_GOOGLE_OAUTH_CLIENT_SECRET_HERE_IF_NEEDED
APP_GOOGLE_ALLOWED_AUDIENCES=PASTE_GOOGLE_OAUTH_CLIENT_ID_HERE

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_BOOTSTRAP_ADMIN_USERNAME=admin
APP_BOOTSTRAP_ADMIN_PASSWORD=admin123456
